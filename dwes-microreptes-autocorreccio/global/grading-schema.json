{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/dwes/grading-schema.json",
  "title": "DWES Microrepte Grading Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "challenge_id",
    "student",
    "commit",
    "final_score_over_10",
    "provisional",
    "dimension_scores",
    "strengths",
    "weaknesses",
    "blocking_flags",
    "teacher_review_required",
    "confidence",
    "short_feedback_md"
  ],
  "properties": {
    "challenge_id": { "type": "string", "minLength": 1 },
    "student": { "type": "string", "minLength": 1 },
    "commit": { "type": "string", "minLength": 7 },
    "final_score_over_10": { "type": "number", "minimum": 0, "maximum": 10 },
    "provisional": { "type": "boolean" },
    "dimension_scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "score", "max_score", "reason"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "score": { "type": "number", "minimum": 0 },
          "max_score": { "type": "number", "exclusiveMinimum": 0 },
          "reason": { "type": "string" }
        }
      }
    },
    "strengths": { "type": "array", "items": { "type": "string" } },
    "weaknesses": { "type": "array", "items": { "type": "string" } },
    "blocking_flags": { "type": "array", "items": { "type": "string" } },
    "teacher_review_required": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "short_feedback_md": { "type": "string" }
  }
}
